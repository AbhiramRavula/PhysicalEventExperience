datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Venue {
  id           String   @id @default(uuid())
  name         String
  city         String?
  country_code String?
  capacity     Int?
  geom         String?  // MVP: Store GeoJSON as string
  createdAt    DateTime @default(now())

  zones  Zone[]
  orders Order[]
  products Product[]
}

model Zone {
  id       String  @id @default(uuid())
  venueId  String
  venue    Venue   @relation(fields: [venueId], references: [id])
  name     String
  type     String?
  floor    Int     @default(0)
  capacity Int?
  geom     String? // MVP: Store GeoJSON as string
  centroid String? // MVP: Store Point JSON string

  beacons         Beacon[]
  crowdTelemetries CrowdTelemetry[]
  pickupOrders    Order[] @relation("PickupZone")
}

model Beacon {
  id         String   @id @default(uuid())
  zoneId     String
  zone       Zone     @relation(fields: [zoneId], references: [id])
  hardwareId String   @unique
  location   String?  // JSON string point
  floor      Int?
  batteryPct Int?
  lastSeen   DateTime?
}

model CrowdTelemetry {
  id          String   @id @default(uuid())
  time        DateTime
  zoneId      String
  zone        Zone     @relation(fields: [zoneId], references: [id])
  deviceCount Int?
  densityPct  Float?
  flowDir     String?
  source      String?

  @@index([zoneId, time(sort: Desc)])
}

model Product {
  id        String  @id @default(uuid())
  venueId   String
  venue     Venue   @relation(fields: [venueId], references: [id])
  name      String
  category  String
  price     Float
  currency  String  @default("INR")
  available Boolean @default(true)

  orderItems OrderItem[]
}

model Order {
  id           String    @id @default(uuid())
  attendeeId   String
  eventId      String
  venueId      String?
  venue        Venue?    @relation(fields: [venueId], references: [id])
  status       String    @default("pending")
  orderType    String?
  pickupZoneId String?
  pickupZone   Zone?     @relation("PickupZone", fields: [pickupZoneId], references: [id])
  totalAmount  Float?
  currency     String    @default("INR")
  paymentRef   String?
  createdAt    DateTime  @default(now())
  readyAt      DateTime?
  collectedAt  DateTime?

  items OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float?
}
